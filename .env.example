# othoni configuration
# Copy this file to `.env` and edit the values.

# Port to run the dashboard on
PORT=8088

# Bind address (0.0.0.0 = all interfaces, 127.0.0.1 = localhost only)
HOST=0.0.0.0

# Login credentials
OTHONI_ADMIN_USER=admin
OTHONI_ADMIN_PASSWORD=admin123

# Optional: scrypt hash of the admin password. When set, takes precedence
# over OTHONI_ADMIN_PASSWORD. Generate with `npm run hash-password`. The
# hash format is self-describing — no separate salt to track.
# OTHONI_ADMIN_PASSWORD_HASH=scrypt$N=32768,r=8,p=1$<base64-salt>$<base64-hash>

# Optional read-only second user. When set, this account can log in and
# view every page but every state-changing API call (PUT/POST/PATCH/DELETE)
# returns 403. The viewer doesn't see the same role on the UI either —
# destructive controls hide. Prefer the hash variant in production.
# OTHONI_VIEWER_USER=viewer
# OTHONI_VIEWER_PASSWORD=viewer123
# OTHONI_VIEWER_PASSWORD_HASH=scrypt$N=32768,r=8,p=1$<base64-salt>$<base64-hash>

# JWT signing secret. CHANGE THIS in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
OTHONI_JWT_SECRET=change-me-please-use-a-long-random-string

# Session length (e.g. 12h, 7d)
OTHONI_SESSION_TTL=12h

# Optional TOTP (RFC 6238) second factor on login. When set, every login
# requires a 6-digit authenticator code in addition to username+password.
# Generate a secret with: npm run totp:setup
# OTHONI_TOTP_SECRET=BASE32-SECRET-FROM-totp-setup

# Historical samples store (SQLite, single file)
OTHONI_DB=data/othoni.db

# Sampling cadence + retention for the in-process history store
OTHONI_SAMPLE_MS=5000
OTHONI_RETENTION_MS=86400000

# Cadence for the process-trends sampler (Top-N by cpu/mem snapshots that feed
# the Trends card on the Processes page). Slower by default than the metrics
# sampler because process churn is noisier and would inflate the DB.
OTHONI_PROC_SAMPLE_MS=30000

# Optional Prometheus exporter. When set, exposes /metrics in the standard
# text-based exposition format. Auth is via `Authorization: Bearer <token>`
# (constant-time compared, separate from the dashboard session). Generate one
# with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# OTHONI_PROMETHEUS_TOKEN=generate-a-strong-random-string

# Optional bulk archive export (v0.49) at /api/export?from=&to=. NDJSON
# stream covering samples / process_samples / alert_fires / audit_log /
# webhook_deliveries / action_history. Bearer-auth; separate token from
# the Prom exporter so they can be rotated independently. Set this to
# enable; unset leaves the endpoint 404. Default row cap is 1_000_000;
# override via OTHONI_EXPORT_MAX_ROWS.
# OTHONI_EXPORT_TOKEN=generate-a-strong-random-string
# OTHONI_EXPORT_MAX_ROWS=1000000

# Enable the system log feed (/api/logs + Logs page). Off by default —
# journalctl entries can leak sensitive content (passwords, tokens, IPs in
# error messages, kernel iptables logs with public IPs, full command lines).
# OTHONI_LOGS_ENABLED=true

# Enable opt-in write actions (/api/actions/run). Off by default — the
# write surface restarts services, starts/stops containers, and signals
# processes. Every invocation is audit-logged.
# OTHONI_ACTIONS_ENABLED=true

# Comma-separated whitelist of systemd units the dashboard may restart.
# Defaults to the same list of units the Services page already monitors
# (nginx, apache2, docker, ssh, sshd, postgresql, mysql, mariadb,
# redis, redis-server, mongodb, mongod). Set to override.
# OTHONI_ACTION_UNIT_WHITELIST=nginx,my-app,php-fpm

# Self-protection: refuse to restart this unit (othoni's own systemd
# service) regardless of the whitelist, so the dashboard can't kill its
# own response mid-action. Defaults to "othoni"; override if the local
# unit is named something else.
# OTHONI_SELF_UNIT=othoni

# Self-protection for Docker: when set, the dashboard refuses to
# start/stop/restart this container. Useful when running othoni itself
# inside Docker so the dashboard can't kill its own container.
# OTHONI_SELF_CONTAINER=othoni

# Self-protection for process.signal: regex against /proc/<pid>/comm.
# Matching processes can't be signaled from the dashboard. The default
# ^(systemd|init|sshd|nginx)$ guards the obvious ingress + critical
# system processes. Set to "none" to disable (not recommended). PID 1
# and the dashboard's own PID are refused unconditionally regardless of
# this value.
# OTHONI_PROCESS_GUARD=^(systemd|init|sshd|nginx)$

# CSRF protection (v0.39) — double-submit cookie pattern on every
# state-changing API route (PUT/POST/PATCH/DELETE) under the cookie
# auth wall. Defaults to on. Set to "false" to disable if some
# embedded usage breaks; the client-side wrapper attaches the header
# automatically when the cookie is present.
# OTHONI_CSRF_ENABLED=true

# Nightly SQLite VACUUM scheduler (v0.48). HH:MM local time. SQLite
# never reclaims pages from deleted rows on its own — the WAL accretes
# them. VACUUM defragments + reclaims. Brief blocking write while it
# runs; default 03:30 to avoid most workloads. Set to "off" / "false"
# / empty to disable.
# OTHONI_VACUUM_TIME=03:30

# Login lockout (v0.40). After N consecutive failed logins from the
# same IP, that IP is locked for M milliseconds — the login endpoint
# returns 429 with a Retry-After header, no credential check, no
# scrypt CPU spent. Successful login clears the counter for that IP.
# Defaults to 5 fails, 15-minute lock. Memory-only; resets on process
# restart. Surfaced on /api/health as auth.lockout.{enabled, lockedNow,
# degraded} for monitoring / status-page integration.
# OTHONI_LOGIN_LOCKOUT_FAILS=5
# OTHONI_LOGIN_LOCKOUT_MS=900000

# Email notification channel (v0.59). When configured, webhook records
# with `format: 'email'` deliver via SMTP submission instead of HTTP
# POST. Set OTHONI_SMTP_HOST + OTHONI_SMTP_FROM to enable; the email
# webhook format returns a clean error when these are unset.
# OTHONI_SMTP_HOST=smtp.example.com
# OTHONI_SMTP_PORT=587
# OTHONI_SMTP_USER=othoni@example.com
# OTHONI_SMTP_PASS=app-password-or-token
# OTHONI_SMTP_FROM=othoni@example.com
# Set SECURE=true for direct TLS on port 465 instead of STARTTLS on 587.
# OTHONI_SMTP_SECURE=false
# Escape hatch for self-signed internal relays. Off by default — leave
# off when talking to public providers (Gmail / SendGrid / Mailgun).
# OTHONI_SMTP_INSECURE=false

# Set to "production" on a real VPS
NODE_ENV=production
