# Example nginx server block for othoni.
#
# Drop into /etc/nginx/sites-available/othoni and link from sites-enabled,
# or paste into /etc/nginx/conf.d/othoni.conf — your distro's choice.
# Replace `othoni.example.com` with your hostname.
#
# Prerequisites:
#   1. othoni listening on 127.0.0.1:8088 (the install.sh default)
#   2. A TLS cert. The simplest path: install certbot and run
#         sudo certbot --nginx -d othoni.example.com
#      Certbot will fill in the ssl_certificate paths below automatically;
#      if you'd rather manage it by hand, point them at your live PEM files.
#   3. othoni.service.example uses `app.set('trust proxy', 1)`, so the
#      X-Forwarded-* headers below are honored cleanly by express-rate-limit
#      and the secure-cookie logic.

# Plain-HTTP redirect.
server {
    listen 80;
    listen [::]:80;
    server_name othoni.example.com;
    return 301 https://$host$request_uri;
}

# HTTPS server.
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name othoni.example.com;

    # Filled in by certbot --nginx, or set manually:
    ssl_certificate     /etc/letsencrypt/live/othoni.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/othoni.example.com/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;

    # The dashboard never serves user uploads. 1 MB is more than enough for
    # the largest expected POST (an /api/metrics batch capped at 256 KB).
    client_max_body_size 1m;

    # Reasonable defaults for an internal monitoring app — never cache the SPA
    # shell or the JSON API. Vite-built static asset paths are content-hashed,
    # so the dashboard auto-refreshes without surprise stale content.
    add_header Cache-Control "no-store" always;

    # Don't expose the upstream banner to the world.
    server_tokens off;

    location / {
        proxy_pass         http://127.0.0.1:8088;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_buffering    off;
        proxy_read_timeout 60s;
    }
}
